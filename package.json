{
  "name": "settings-agent-poc",
  "version": "0.1.0",
  "description": "PoC for using a coding agent with Appium MCP to explore the Android Settings app",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "validate-env": "node scripts/validate-environment.mjs",
    "poc": "node scripts/run-poc.mjs",
    "poc:prepare": "node scripts/run-poc.mjs --prepare-only",
    "poc:finalize": "node scripts/run-poc.mjs --finalize",
    "poc:explore": "node scripts/run-poc.mjs --explore-only",
    "poc:reachability": "node scripts/run-poc.mjs --reachability-only",
    "validate-artifacts": "node scripts/validate-artifacts.mjs",
    "report": "node scripts/generate-report.mjs"
  }
}
