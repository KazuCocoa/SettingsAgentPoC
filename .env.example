# Appium Server Configuration
APPIUM_HOST=localhost
APPIUM_PORT=4723

# Android Configuration
ANDROID_HOME=/path/to/android/sdk
ADB_PATH=adb

# Timeout Configuration (in milliseconds)
ACTION_TIMEOUT=30000
SESSION_TIMEOUT=120000

# Run Configuration
LOG_LEVEL=info
SKIP_ENV_VALIDATION=false

# Agent Configuration
# Supported values: codex, copilot
AGENT_PROVIDER=codex
# Leave unset to use the selected CLI default model.
# AGENT_MODEL=
AGENT_CLI_TIMEOUT_MS=600000
# Optional Codex-specific override. If unset, Codex gets at least 600000ms.
# CODEX_CLI_TIMEOUT_MS=600000
# Keep Codex runs terse and bounded for Appium automation.
CODEX_FAST_MODE=true
# Required for non-interactive Codex runs that execute MCP tool calls.
CODEX_BYPASS_APPROVALS_AND_SANDBOX=true

# Appium MCP Configuration
# Codex and VS Code start this stdio MCP server automatically.
APPIUM_MCP_ENABLED=true
APPIUM_MCP_COMMAND=bash
APPIUM_MCP_ARGS=scripts/appium-mcp-with-log.sh
APPIUM_MCP_LOG_FILE=artifacts/logs/appium-mcp.log
