{
  "servers": {
    "appium-mcp": {
      "type": "stdio",
      "command": "sh",
      "args": ["${workspaceFolder}/scripts/appium-mcp-with-log.sh"],
      "env": {
        "ANDROID_HOME": "${env:ANDROID_HOME}",
        "APPIUM_MCP_LOG_FILE": "${workspaceFolder}/artifacts/logs/appium-mcp.log",
        "NO_UI": "true"
      }
    }
  }
}
